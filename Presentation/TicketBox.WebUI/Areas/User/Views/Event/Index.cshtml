@model List<ResultEventDto>
@{
    ViewData["Title"] = "Etkinlikler";
    Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";
}

<section class="user-events">
    <div class="user-events__head glass-panel">
        <div>
            <span class="eyebrow">Keşfet</span>
            <h2 class="user-events__title">Tüm Etkinlikler</h2>
            <p class="user-events__subtitle">@Model.Count etkinlik listeleniyor — biletini hemen ayırt.</p>
        </div>
    </div>

    <div class="user-events__grid">
        @foreach (var item in Model)
        {
            <article class="user-event-card glass-panel">
                <a href="/User/Event/EventDetail/@item.EventId" class="user-event-card__poster">
                    <img src="@item.ImageUrl" alt="@item.Title" loading="lazy">
                    <div class="user-event-card__tags">
                        <span class="user-event-card__badge">@item.CategoryName</span>
                        @if (item.IsFeatured == true)
                        {
                            <span class="user-event-card__badge user-event-card__badge--featured">Öne Çıkan</span>
                        }
                    </div>
                </a>
                <div class="user-event-card__body">
                    <h3 class="user-event-card__title">
                        <a href="/User/Event/EventDetail/@item.EventId">@item.Title</a>
                    </h3>
                    <p class="user-event-card__desc">@item.Description</p>
                    <div class="user-event-card__meta">
                        <span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                            @item.EventDate.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                        </span>
                        <span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
                            @item.Location
                        </span>
                        <span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                            @item.Capacity kişi
                        </span>
                    </div>
                    <div class="user-event-card__footer">
                        <div class="user-event-card__price">
                            <small>Başlangıç</small>
                            <strong>@item.Price.ToString("N0")₺</strong>
                        </div>
                        <a href="/User/Event/EventDetail/@item.EventId" class="btn btn-primary">Detay</a>
                    </div>
                </div>
            </article>
        }
    </div>
</section>
