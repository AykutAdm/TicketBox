@model UserProfileDto
@{
    ViewData["Title"] = "Profil";
    Layout = "~/Areas/User/Views/Shared/_UserLayout.cshtml";

    var initials = "?";
    var displayName = "Kullanıcı";

    if (Model != null)
    {
        initials = string.Concat(Model.FirstName?.FirstOrDefault(), Model.LastName?.FirstOrDefault());
        if (string.IsNullOrWhiteSpace(initials))
        {
            initials = Model.UserName?.FirstOrDefault().ToString() ?? "?";
        }

        initials = initials.ToUpperInvariant();
        displayName = $"{Model.FirstName} {Model.LastName}".Trim();
        if (string.IsNullOrWhiteSpace(displayName))
        {
            displayName = Model.UserName ?? "Kullanıcı";
        }
    }
}

<section class="profile-page">
    @if (Model == null)
    {
        <div class="profile-empty glass-panel">
            <div class="profile-empty__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
            </div>
            <h2>Profil bilgileri yüklenemedi</h2>
            <p>Oturumunuz sona ermiş olabilir. Lütfen tekrar giriş yapın.</p>
            <a href="/Auth/Login" class="btn btn-primary">Giriş Yap</a>
        </div>
    }
    else
    {
        <div class="profile-hero glass-panel">
            <div class="profile-hero__glow" aria-hidden="true"></div>
            <div class="profile-hero__main">
                <div class="profile-avatar">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl" alt="@displayName">
                    }
                    else
                    {
                        <span>@initials</span>
                    }
                </div>
                <div class="profile-hero__info">
                    <span class="eyebrow">Hesap Profili</span>
                    <h2 class="profile-hero__name">@displayName</h2>
                    <p class="profile-hero__email">@Model.Email</p>
                    <div class="profile-hero__badges">
                        <span class="profile-badge">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="M22 4 12 14.01l-3-3" /></svg>
                            Doğrulanmış hesap
                        </span>
                        <span class="profile-badge profile-badge--soft">@Model.UserName</span>
                    </div>
                </div>
            </div>
            <div class="profile-hero__actions">
                <button type="button" class="btn btn-primary" disabled>Düzenle</button>
                <button type="button" class="btn btn-ghost" disabled>Fotoğraf Değiştir</button>
            </div>
        </div>

        <div class="profile-grid">
            <article class="profile-card glass-panel">
                <header class="profile-card__head">
                    <div class="profile-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                    </div>
                    <div>
                        <h3>Kişisel Bilgiler</h3>
                        <p>Temel profil detayların</p>
                    </div>
                </header>
                <dl class="profile-fields">
                    <div class="profile-field">
                        <dt>Ad</dt>
                        <dd>@(Model.FirstName ?? "—")</dd>
                    </div>
                    <div class="profile-field">
                        <dt>Soyad</dt>
                        <dd>@(Model.LastName ?? "—")</dd>
                    </div>
                    <div class="profile-field">
                        <dt>Kullanıcı Adı</dt>
                        <dd>@(Model.UserName ?? "—")</dd>
                    </div>
                </dl>
            </article>

            <article class="profile-card glass-panel">
                <header class="profile-card__head">
                    <div class="profile-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    </div>
                    <div>
                        <h3>Şifre Değiştir</h3>
                        <p>Hesap güvenliğin için yeni şifre belirle</p>
                    </div>
                </header>
                <form class="profile-password-form" action="#" method="post" onsubmit="return false;">
                    <div class="profile-form-field">
                        <label for="currentPassword">Mevcut Şifre</label>
                        <input id="currentPassword" type="password" placeholder="••••••••" autocomplete="current-password">
                    </div>
                    <div class="profile-form-field">
                        <label for="newPassword">Yeni Şifre</label>
                        <input id="newPassword" type="password" placeholder="En az 8 karakter" autocomplete="new-password">
                    </div>
                    <div class="profile-form-field">
                        <label for="confirmPassword">Yeni Şifre (Tekrar)</label>
                        <input id="confirmPassword" type="password" placeholder="Yeni şifreni tekrar gir" autocomplete="new-password">
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Şifreyi Güncelle</button>
                </form>
            </article>
        </div>

        <div class="profile-stats">
            <div class="profile-stat glass-panel">
                <span class="profile-stat__value">0</span>
                <span class="profile-stat__label">Aktif Bilet</span>
            </div>
            <div class="profile-stat glass-panel">
                <span class="profile-stat__value">0</span>
                <span class="profile-stat__label">Katıldığı Etkinlik</span>
            </div>
        </div>
    }
</section>
